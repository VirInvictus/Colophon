<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="OverviewPage" parent="GtkWidget">
    <child>
      <object class="GtkScrolledWindow">
        <property name="hscrollbar-policy">never</property>
        <property name="vexpand">true</property>
        <child>
          <object class="AdwClamp">
            <property name="maximum-size">820</property>
            <property name="tightening-threshold">640</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="spacing">18</property>
                <property name="margin-top">18</property>
                <property name="margin-bottom">24</property>
                <property name="margin-start">12</property>
                <property name="margin-end">12</property>
                <child>
                  <object class="GtkBox">
                    <property name="halign">start</property>
                    <style>
                      <class name="linked"/>
                    </style>
                    <child>
                      <object class="GtkToggleButton" id="win_30">
                        <property name="label">30d</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="win_90">
                        <property name="label">90d</property>
                        <property name="group">win_30</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="win_365">
                        <property name="label">365d</property>
                        <property name="group">win_30</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="win_all">
                        <property name="label">All time</property>
                        <property name="active">true</property>
                        <property name="group">win_30</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkFlowBox" id="tiles">
                    <property name="selection-mode">none</property>
                    <property name="homogeneous">true</property>
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">12</property>
                    <property name="max-children-per-line">4</property>
                    <property name="min-children-per-line">2</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="profile_title">
                    <property name="label">Reading personality</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkFlowBox" id="profile_tiles">
                    <property name="selection-mode">none</property>
                    <property name="homogeneous">true</property>
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">12</property>
                    <property name="max-children-per-line">3</property>
                    <property name="min-children-per-line">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="record_title">
                    <property name="label">Records</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkFlowBox" id="record_tiles">
                    <property name="selection-mode">none</property>
                    <property name="homogeneous">true</property>
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">12</property>
                    <property name="max-children-per-line">3</property>
                    <property name="min-children-per-line">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="recap_title">
                    <property name="label">Recap</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkFlowBox" id="recap_tiles">
                    <property name="selection-mode">none</property>
                    <property name="homogeneous">true</property>
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">12</property>
                    <property name="max-children-per-line">3</property>
                    <property name="min-children-per-line">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="finished_title">
                    <property name="label">Finished books</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkListBox" id="finished_rows">
                    <property name="selection-mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Reading activity</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="vscrollbar-policy">never</property>
                    <property name="hscrollbar-policy">automatic</property>
                    <child>
                      <object class="YearHeatmap" id="heatmap">
                        <property name="halign">start</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">When do I read</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="vscrollbar-policy">never</property>
                    <property name="hscrollbar-policy">automatic</property>
                    <child>
                      <object class="HourHeatmap" id="hour_heatmap">
                        <property name="halign">start</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="speed_title">
                    <property name="label">Reading speed</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="LineChart" id="speed_chart"/>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Sessions</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="session_caption">
                    <property name="xalign">0</property>
                    <property name="wrap">true</property>
                    <style>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="BarChart" id="session_chart"/>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Session starts by hour</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="caption"/>
                      <class name="dim-label"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="BarChart" id="session_starts_chart"/>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Average time by weekday</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="BarChart" id="weekday_chart"/>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">By month</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="BarChart" id="monthly_chart"/>
                </child>
                <child>
                  <object class="GtkLabel" id="series_title">
                    <property name="label">Series</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkListBox" id="series_rows">
                    <property name="selection-mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="author_title">
                    <property name="label">Authors</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkListBox" id="author_rows">
                    <property name="selection-mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="forgotten_title">
                    <property name="label">Set aside</property>
                    <property name="xalign">0</property>
                    <style>
                      <class name="title-4"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkListBox" id="forgotten_rows">
                    <property name="selection-mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
