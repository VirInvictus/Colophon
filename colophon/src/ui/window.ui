<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label">Hide Short Reads</attribute>
        <attribute name="action">win.junk-filter</attribute>
      </item>
      <item>
        <attribute name="label">Toggle Sidebar</attribute>
        <attribute name="action">win.toggle-sidebar</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Preferences</attribute>
        <attribute name="action">win.preferences</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">About Colophon</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
  <template class="ColophonWindow" parent="GtkApplicationWindow">
    <property name="title">Colophon</property>
    <property name="titlebar">
      <object class="GtkHeaderBar" id="header_bar">
        <property name="show-title-buttons">false</property>
        <property name="title-widget">
          <object class="GtkLabel" id="content_title">
            <property name="label">Colophon</property>
            <property name="single-line-mode">true</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </property>
        <child type="start">
          <object class="GtkButton">
            <property name="icon-name">document-open-symbolic</property>
            <property name="tooltip-text">Import statistics database</property>
            <property name="action-name">win.import</property>
          </object>
        </child>
        <child type="start">
          <object class="GtkButton" id="refresh_button">
            <property name="icon-name">view-refresh-symbolic</property>
            <property name="tooltip-text">Re-import from the last source</property>
            <property name="action-name">win.refresh</property>
          </object>
        </child>
        <child type="end">
          <object class="GtkMenuButton">
            <property name="icon-name">open-menu-symbolic</property>
            <property name="tooltip-text">Main menu</property>
            <property name="menu-model">primary_menu</property>
          </object>
        </child>
      </object>
    </property>
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkOverlay" id="toast_overlay">
            <property name="vexpand">true</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkRevealer" id="schema_banner">
                    <property name="reveal-child">false</property>
                    <property name="child">
                      <object class="GtkLabel" id="schema_banner_label">
                        <property name="wrap">true</property>
                        <property name="justify">center</property>
                        <style>
                          <class name="banner"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkPaned" id="paned">
                    <property name="vexpand">true</property>
                    <property name="shrink-start-child">false</property>
                    <property name="resize-start-child">false</property>
                    <property name="start-child">
                      <object class="GtkBox" id="sidebar_box">
                        <property name="orientation">vertical</property>
                        <property name="width-request">280</property>
                        <style>
                          <class name="sidebar"/>
                        </style>
                        <child>
                          <object class="GtkStack" id="library_stack">
                            <property name="transition-type">crossfade</property>
                            <property name="vexpand">true</property>
                            <child>
                              <object class="GtkStackPage">
                                <property name="name">empty</property>
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <property name="vexpand">true</property>
                                    <style>
                                      <class name="status-page"/>
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">No Statistics Yet</property>
                                        <property name="wrap">true</property>
                                        <property name="justify">center</property>
                                        <style>
                                          <class name="status-title"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Import a copy of KOReader's statistics.sqlite3 to get started. The original file is never modified.</property>
                                        <property name="wrap">true</property>
                                        <property name="justify">center</property>
                                        <property name="max-width-chars">40</property>
                                        <style>
                                          <class name="dim-label"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton">
                                        <property name="label">Import…</property>
                                        <property name="action-name">win.import</property>
                                        <property name="halign">center</property>
                                        <property name="margin-top">6</property>
                                        <style>
                                          <class name="suggested-action"/>
                                        </style>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStackPage">
                                <property name="name">loading</property>
                                <property name="child">
                                  <object class="GtkSpinner">
                                    <property name="spinning">true</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <property name="width-request">32</property>
                                    <property name="height-request">32</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStackPage">
                                <property name="name">list</property>
                                <property name="child">
                                  <object class="LibraryView" id="library_view"/>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                    <property name="end-child">
                      <object class="GtkStack" id="content_stack">
                        <property name="transition-type">crossfade</property>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">placeholder</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">8</property>
                                <property name="halign">center</property>
                                <property name="valign">center</property>
                                <property name="vexpand">true</property>
                                <style>
                                  <class name="status-page"/>
                                </style>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">Colophon</property>
                                    <property name="wrap">true</property>
                                    <property name="justify">center</property>
                                    <style>
                                      <class name="status-title"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">Import statistics to see your reading here.</property>
                                    <property name="wrap">true</property>
                                    <property name="justify">center</property>
                                    <property name="max-width-chars">40</property>
                                    <style>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">overview</property>
                            <property name="child">
                              <object class="OverviewPage" id="overview_page"/>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">book</property>
                            <property name="child">
                              <object class="BookPage" id="book_page"/>
                            </property>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </property>
            <child type="overlay">
              <object class="GtkRevealer" id="toast_revealer">
                <property name="reveal-child">false</property>
                <property name="halign">center</property>
                <property name="valign">end</property>
                <property name="margin-bottom">12</property>
                <property name="transition-type">crossfade</property>
                <property name="can-target">false</property>
                <property name="child">
                  <object class="GtkLabel" id="toast_label">
                    <property name="ellipsize">end</property>
                    <property name="max-width-chars">60</property>
                    <style>
                      <class name="toast"/>
                    </style>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
