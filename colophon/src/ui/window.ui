<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label">Hide Short Reads</attribute>
        <attribute name="action">win.junk-filter</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Preferences</attribute>
        <attribute name="action">win.preferences</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">About Colophon</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
  <template class="ColophonWindow" parent="AdwApplicationWindow">
    <property name="title">Colophon</property>
    <property name="content">
      <object class="AdwToastOverlay" id="toast_overlay">
        <property name="child">
          <object class="AdwNavigationSplitView" id="split_view">
            <property name="sidebar-width-fraction">0.42</property>
            <property name="min-sidebar-width">300</property>
            <property name="max-sidebar-width">460</property>
            <property name="sidebar">
              <object class="AdwNavigationPage">
                <property name="title">Library</property>
                <property name="child">
                  <object class="AdwToolbarView">
                    <child type="top">
                      <object class="AdwHeaderBar">
                        <child type="start">
                          <object class="GtkButton">
                            <property name="icon-name">document-open-symbolic</property>
                            <property name="tooltip-text">Import statistics database</property>
                            <property name="action-name">win.import</property>
                          </object>
                        </child>
                        <child type="start">
                          <object class="GtkButton" id="refresh_button">
                            <property name="icon-name">view-refresh-symbolic</property>
                            <property name="tooltip-text">Re-import from the last source</property>
                            <property name="action-name">win.refresh</property>
                          </object>
                        </child>
                        <child type="end">
                          <object class="GtkMenuButton">
                            <property name="icon-name">open-menu-symbolic</property>
                            <property name="tooltip-text">Main menu</property>
                            <property name="menu-model">primary_menu</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child type="top">
                      <object class="AdwBanner" id="schema_banner">
                        <property name="revealed">false</property>
                      </object>
                    </child>
                    <property name="content">
                      <object class="GtkStack" id="library_stack">
                        <property name="transition-type">crossfade</property>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">empty</property>
                            <property name="child">
                              <object class="AdwStatusPage">
                                <property name="title">No Statistics Yet</property>
                                <property name="description">Import a copy of KOReader's statistics.sqlite3 to get started. The original file is never modified.</property>
                                <property name="child">
                                  <object class="GtkButton">
                                    <property name="label">Import…</property>
                                    <property name="action-name">win.import</property>
                                    <property name="halign">center</property>
                                    <style>
                                      <class name="pill"/>
                                      <class name="suggested-action"/>
                                    </style>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">loading</property>
                            <property name="child">
                              <object class="GtkSpinner">
                                <property name="spinning">true</property>
                                <property name="halign">center</property>
                                <property name="valign">center</property>
                                <property name="width-request">32</property>
                                <property name="height-request">32</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">list</property>
                            <property name="child">
                              <object class="LibraryView" id="library_view"/>
                            </property>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
            <property name="content">
              <object class="AdwNavigationPage" id="content_page">
                <property name="title">Colophon</property>
                <property name="child">
                  <object class="AdwToolbarView">
                    <child type="top">
                      <object class="AdwHeaderBar"/>
                    </child>
                    <property name="content">
                      <object class="GtkStack" id="content_stack">
                        <property name="transition-type">crossfade</property>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">placeholder</property>
                            <property name="child">
                              <object class="AdwStatusPage">
                                <property name="title">Colophon</property>
                                <property name="description">Import statistics to see your reading here.</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">overview</property>
                            <property name="child">
                              <object class="OverviewPage" id="overview_page"/>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">book</property>
                            <property name="child">
                              <object class="BookPage" id="book_page"/>
                            </property>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </property>
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 640sp</condition>
        <setter object="split_view" property="collapsed">True</setter>
      </object>
    </child>
  </template>
</interface>
